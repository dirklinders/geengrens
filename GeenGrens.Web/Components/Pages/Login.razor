@page "/login"
@inject HttpClient Http
@inject NavigationManager Navigation
@rendermode InteractiveServer
@attribute [AllowAnonymous]

<PageTitle>Login</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card p-4" style="width: 350px;">
        <h3 class="card-title text-center mb-3">Login</h3>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }

        <!-- Email / Password Form -->
        <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="LoginForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <InputText id="email" class="form-control" @bind-Value="loginModel.Email" />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="loginModel.Password" />
            </div>

            <div class="form-check mb-3">
                <InputCheckbox id="rememberMe" class="form-check-input" @bind-Value="loginModel.RememberMe" />
                <label class="form-check-label" for="rememberMe">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary w-100">Login</button>
        </EditForm>

        <hr />

        <!-- Google Login Button -->
        <button class="btn btn-danger w-100" @onclick="LoginWithGoogle">
            <i class="bi bi-google"></i> Login with Google
        </button>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string? returnUrl;
    private string? ErrorMessage;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("returnUrl", out var url))
        {
            returnUrl = url;
        }
        else
        {
            returnUrl = "/";
        }
    }

    private async Task HandleLogin()
    {
        ErrorMessage = null;

        // Debug check
        Console.WriteLine("HandleLogin fired!");

        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/login", loginModel);
            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo(returnUrl ?? "/");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                ErrorMessage = !string.IsNullOrWhiteSpace(error) ? error : "Login failed";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error: {ex.Message}";
        }
    }

    private string BackendBaseUrl = "https://localhost:7424"; // development backend URL

    private void LoginWithGoogle()
    {
        #if DEBUG
        var url = $"{BackendBaseUrl}/api/externalauth/logingoogle?returnUrl={Uri.EscapeDataString($"CallBackGoogle?returnUrl={Uri.EscapeDataString(returnUrl ?? "")}")}";
        Navigation.NavigateTo(url, true); // full reload to backend
        #else

        var url = $"/api/externalauth/logingoogle?returnUrl={Uri.EscapeDataString(returnUrl ?? "/")}";
        Navigation.NavigateTo(url, true); // full reload to backend
        #endif
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string? Email { get; set; }

        [Required(ErrorMessage = "Password is required")]
        public string? Password { get; set; }

        public bool RememberMe { get; set; }
    }
}