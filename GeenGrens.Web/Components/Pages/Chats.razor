@page "/chat"
@using GeenGrens.Web.Clients
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>chat</PageTitle>
@inject ChatApiClient ChatApi

<h1>CHAT</h1>

<p>This is your chathistory with burgemester</p>

@if (chats == null)
{
    <p><em>Loading...</em></p>
}
else
{
    
    <table class="table">
        <thead>
            <tr>
                <th>Who</th>
                <th>Message</th>
            </tr>
        </thead>
        <tbody>
            
            @foreach (var chat in chats)
            {
                <tr>
                    <td>@(isUser ? "You" : "Burgemeester")</td>
                    <td>@chat</td>
                </tr>
                { isUser = !isUser; }

            }
        </tbody>
    </table>
}

<div class="mt-3">
    <input @bind="question" placeholder="Type your question..." class="form-control" @onkeypress="HandleKeyPress" />
    <button class="btn btn-primary mt-2" @onclick="SendQuestion">Send</button>
</div>

@code {
    private List<string>? chats;
    private bool isUser = true;

    protected override async Task OnInitializedAsync()
    {
        chats = await ChatApi.GetChatsAsync();
    }

    private string question = "";

    // Represents a single chat entry
    private class ChatMessage
    {
        public string Sender { get; set; } = "";
        public string Message { get; set; } = "";
    }

    // Called when the button is clicked
    private async Task SendQuestion()
    {
        if (string.IsNullOrWhiteSpace(question))
            return;

        // Add the user's question
        chats.Add(question);
        var tempQuest = question;
        // Clear the input
        question = "";

        // Call your API client
        var response = await ChatApi.GetNextResponse(tempQuest);

        isUser = true;
        // Add the AI's response
        chats = response;


        
    }

    // Optional: allow pressing Enter to send
    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendQuestion();
        }
    }
}
