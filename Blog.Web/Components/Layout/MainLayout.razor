@inherits LayoutComponentBase

<div class="page">   

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
/* --- Basis & Layout --- */
* { box-sizing: border-box; }

body { 
    margin: 0; 
    padding: 0; 
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
    background-color: #f9f9f9; 
    color: #222;
    line-height: 1.6;
}

.viewport {
    max-width: 600px;
    margin: 0 auto;
    background: #fff;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

/* --- Header & Navigatie --- */
.mobile-header {
    padding: 30px 20px;
    text-align: center;
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
}

.brand { 
    font-family: 'Georgia', serif; 
    font-weight: bold; 
    font-size: 1.8rem;
    color: #1a3a5f;
    margin: 0; 
}

.tagline {
    font-size: 0.9rem;
    color: #777;
    margin-top: 5px;
}

.sticky-nav {
    position: sticky;
    top: 0;
    display: flex;
    background: #1a3a5f; /* Donkere blauwe balk */
    z-index: 100;
}

.nav-item {
    flex: 1;
    text-align: center;
    padding: 15px 5px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.85rem;
    font-weight: bold;
    text-transform: uppercase;
    transition: 0.2s ease;
}

.nav-item.active {
    color: #fff;
    border-bottom: 3px solid #fff;
}

/* --- Homepage Bio Sectie --- */
.content { 
    padding: 0 20px; 
    flex: 1; 
}

.bio-section {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 25px 0;
    margin-bottom: 10px;
    border-bottom: 1px solid #eee;
}

.avatar-circle {
    width: 90px;
    height: 90px;
    background: #e9ecef;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: #adb5bd;
    border: 2px solid #1a3a5f;
    flex-shrink: 0;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.avatar-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.author-name {
    font-size: 1.3rem;
    margin: 0;
    color: #1a3a5f;
    font-weight: bold;
}

.author-title {
    font-size: 0.9rem;
    margin: 2px 0 0;
    color: #666;
}

/* --- Artikelen & Typografie --- */
.blog-post {
    padding-top: 20px;
}

.blog-post h2, .blog-post h3 { 
    font-size: 1.6rem; 
    margin: 10px 0; 
    color: #1a3a5f; 
    line-height: 1.2; 
}

.date { 
    font-size: 0.75rem; 
    color: #999; 
    font-weight: bold; 
    text-transform: uppercase;
}

.blog-post p { 
    margin-bottom: 1.2rem; 
    font-size: 1.05rem; 
}

blockquote {
    margin: 25px 0;
    padding: 15px 20px;
    background: #f8f9fa;
    border-left: 5px solid #1a3a5f;
    font-style: italic;
    color: #444;
}

/* --- Media & Extra's --- */
.image-box {
    margin: 25px -20px;
    background: #eee;
    padding: 50px 20px;
    text-align: center;
}

.caption { 
    font-size: 0.8rem; 
    color: #777; 
    margin-top: 10px; 
}

.quick-facts {
    background: #1a3a5f;
    color: white;
    padding: 25px;
    border-radius: 12px;
    margin: 30px 0;
}

.quick-facts h4 { margin-top: 0; color: #fff; font-size: 1.2rem; }
.quick-facts ul { padding-left: 20px; margin: 0; }
.quick-facts li { margin-bottom: 10px; }

.mobile-footer {
    padding: 30px 20px;
    text-align: center;
    font-size: 0.8rem;
    color: #aaa;
    border-top: 1px solid #eee;
}

/* --- Desktop optimalisaties --- */
@@media (min-width: 600px) {
    .viewport { 
        border-left: 1px solid #eee; 
        border-right: 1px solid #eee; 
    }
    .image-box { 
        margin: 25px 0; 
        border-radius: 8px; 
    }
}
</style>