<div class="viewport">
    <header class="mobile-header">
        <div class="profile-header">            
            <h1 class="brand">Grensverkenner</h1>
            <p class="tagline">Observaties van Viktor Vermeer</p>
        </div>
    </header>

    <nav class="sticky-nav">
        <a href="/" class="nav-item active">Home</a>
        <a href="/historie" class="nav-item">Historie</a>
        <a href="/enclaves" class="nav-item">De Puzzel</a>
    </nav>

    <main class="content">
        <section class="bio-section">
            <div class="avatar-circle">
                <span>FOTO</span>
            </div>
